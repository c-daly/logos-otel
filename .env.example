# Grafana Cloud OTLP credentials
# Get these from: Grafana Cloud → Your Stack → Configure → OpenTelemetry
#
# GRAFANA_CLOUD_OTLP_ENDPOINT is the OTLP gateway URL, e.g.:
#   https://otlp-gateway-prod-us-east-2.grafana.net/otlp
#
# GRAFANA_CLOUD_AUTH_TOKEN is base64(instanceID:apiKey), generate with:
#   echo -n "INSTANCE_ID:API_KEY" | base64
#
GRAFANA_CLOUD_OTLP_ENDPOINT=https://otlp-gateway-prod-us-east-2.grafana.net/otlp
GRAFANA_CLOUD_AUTH_TOKEN=your_base64_encoded_token_here

# Agent Swarm exporter data paths
# Set these to wherever your Claude agent-swarm plugin stores its data.
# Typically: ~/.claude/plugins/agent-swarm/data and ~/.claude/plugins/agent-swarm/dashboard/data
AGENT_SWARM_DATA_DIR=${HOME}/.claude/plugins/agent-swarm/data
AGENT_SWARM_DASHBOARD_DIR=${HOME}/.claude/plugins/agent-swarm/dashboard/data

# Grafana admin password (only used if you disable anonymous access)
# Defaults to "admin" if not set — change for any non-local deployment
GRAFANA_ADMIN_PASSWORD=admin
